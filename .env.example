# Salin file ini menjadi .env lalu isi nilainya.
#
#   cp .env.example .env
#
# --- Bot Telegram ---
# 1) BOT_TOKEN: dapatkan dari @BotFather di Telegram (/newbot).
# 2) ADMIN_ID : ID numerik akun Telegram Anda (kirim /start ke @userinfobot).

BOT_TOKEN=123456789:GANTI-DENGAN-TOKEN-BOT-ANDA
ADMIN_ID=123456789

# --- Web admin ---
# Kata sandi untuk masuk ke dashboard web.
ADMIN_WEB_PASSWORD=admin123
# Secret untuk sesi login web (ganti dengan string acak).
WEB_SECRET=ubah-dengan-string-acak-panjang

# --- Opsional ---
STORE_NAME=Toko Online Mini
CURRENCY=Rp

# --- Force Subscribe ---
# Kosongkan untuk menonaktifkan fitur.
# Isi dengan @username channel ATAU ID negatif channel (contoh: -1001234567890).
# Bot HARUS jadi admin di channel tersebut (minimal hak "Anggota").
FORCE_SUB_CHANNEL=@username_channel_anda
